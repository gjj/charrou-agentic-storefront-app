# GitHub Copilot / GitHub Models API key
# Get yours at: https://github.com/settings/tokens
# Required scopes: read:user (for GitHub Models access)
GITHUB_TOKEN=your_github_token_here

# x402 payment network (optional — defaults to Base Sepolia testnet)
# Production: eip155:8453 (Base mainnet)
# Testnet:    eip155:84532 (Base Sepolia)
X402_NETWORK=eip155:84532
