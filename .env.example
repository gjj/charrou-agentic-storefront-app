# OpenAI API key
# Get yours at: https://platform.openai.com/api-keys
OPENAI_API_KEY=your_openai_api_key_here

# Shopify UCP / Checkout MCP credentials
# Obtain from: https://shopify.dev/docs/apps/build/dev-dashboard
# These are used to authenticate with the Shopify Checkout MCP at checkout.charrou.sg/api/ucp/mcp
SHOPIFY_CLIENT_ID=your_shopify_client_id_here
SHOPIFY_CLIENT_SECRET=your_shopify_client_secret_here

# x402 payment network (optional — defaults to Base Sepolia testnet)
# Production: eip155:8453 (Base mainnet)
# Testnet:    eip155:84532 (Base Sepolia)
X402_NETWORK=eip155:84532
